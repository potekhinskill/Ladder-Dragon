# Этот шаблон соответствует deploy/mybot.service, который запускает Testnet.
# Для Mainnet замените три пути/endpoint на production-файлы явно.
BOT_STATS_DB=/home/bot/apps/binance_bot/db/testnet_bot_stats.db
AI_DECISIONS_DB=/home/bot/apps/binance_bot/db/testnet_ai_decisions.sqlite3
AI_USAGE_LOG=/home/bot/apps/binance_bot/logs/ai_usage.ndjson
AI_RUNTIME_STATUS_FILE=/run/mybot/ai_status.json
DASHBOARD_FOLLOW_BOT_PATHS=1
BINANCE_API_BASE=https://testnet.binance.vision

# Fallback используется только пока heartbeat бота ещё не создан.
AI_MODE=SHADOW
AI_DAILY_COST_LIMIT_USD=0.50
AI_DAILY_TOKEN_LIMIT=100000
AI_MAX_REQUESTS_PER_DAY=1000

# A separate Binance key with read-only permission and withdrawals disabled.
DASHBOARD_BINANCE_API_KEY=replace_with_read_only_key
DASHBOARD_BINANCE_API_SECRET=replace_with_read_only_secret

# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
DASHBOARD_AUTH_TOKEN=replace_with_a_long_random_token
DASHBOARD_TRUST_PROXY_AUTH=0
# Отдельный общий секрет nginx/FastAPI. Installer создаёт его автоматически.
DASHBOARD_PROXY_AUTH_SECRET=replace_with_a_different_long_random_token
DASHBOARD_RATE_LIMIT_PER_MIN=120
DASHBOARD_METRICS_MAX_BYTES=5242880
DASHBOARD_METRICS_ROTATIONS=3
DASHBOARD_PORT=8081
