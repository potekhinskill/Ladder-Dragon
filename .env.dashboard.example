BOT_STATS_DB=/home/bot/apps/binance_bot/db/bot_stats.db
BINANCE_API_BASE=https://api.binance.com

# A separate Binance key with read-only permission and withdrawals disabled.
DASHBOARD_BINANCE_API_KEY=replace_with_read_only_key
DASHBOARD_BINANCE_API_SECRET=replace_with_read_only_secret

# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
DASHBOARD_AUTH_TOKEN=replace_with_a_long_random_token
DASHBOARD_TRUST_PROXY_AUTH=0
DASHBOARD_ENABLE_LOGS=0
DASHBOARD_RATE_LIMIT_PER_MIN=120
DASHBOARD_SSE_MAX_CONNECTIONS=2
DASHBOARD_METRICS_MAX_BYTES=5242880
DASHBOARD_METRICS_ROTATIONS=3
DASHBOARD_PORT=8081
