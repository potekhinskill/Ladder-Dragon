# Venue credentials. Testnet is the default.
BINANCE_TESTNET_API_KEY=replace_me
BINANCE_TESTNET_API_SECRET=replace_me
BINANCE_TESTNET_API_BASE=https://testnet.binance.vision

# Mainnet credentials are only read with --mainnet.
BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
BINANCE_API_BASE=https://api.binance.com

# LIVE requires the exact value YES. Keep unset for DRY mode.
BOT_LIVE_CONFIRMED=NO
# Separate confirmation used only by binance_testnet_smoke.py --mode limit-cancel.
BOT_TESTNET_ORDER_CONFIRMED=NO
# Allows a real Testnet MARKET BUY, verified OCO, cancellation and cleanup SELL.
BOT_TESTNET_BUY_OCO_CONFIRMED=NO
BOT_TESTNET_ORDER_JOURNAL=/home/bot/apps/binance_bot/db/testnet_order_intents.sqlite3
BOT_STATS_DB=/home/bot/apps/binance_bot/db/bot_stats.db
# Durable order intents; must survive process and host restarts.
BOT_ORDER_JOURNAL=/home/bot/apps/binance_bot/db/order_intents.sqlite3
BOT_RUN_DIR=/run/mybot
BOT_CAP_PER_ORDER=50

# Circuit breaker (fractions: 0.03 = 3%).
CB_MAX_DAILY_LOSS_USDT=100
CB_MAX_START_DRAWDOWN_PCT=0.03
CB_MAX_PEAK_DRAWDOWN_PCT=0.02
CB_HALT_FILE=/run/mybot/circuit_halt.json
CB_STATE_FILE=/run/mybot/risk_state.json
CB_ALERTS_FILE=/run/mybot/risk_alerts.ndjson

# Portfolio risk limits.
RISK_PORTFOLIO_CAP_USDT=3000
RISK_DAILY_TURNOVER_CAP_USDT=5000
RISK_DAILY_TRADE_COUNT_CAP=120
RISK_DAILY_BUY_CAP_USDT=2500
RISK_OPEN_ORDER_COUNT_CAP=30
RISK_CORRELATED_SYMBOLS=SOLUSDT,ETHUSDT,TONUSDT
RISK_CORRELATED_CAP_USDT=2500
RISK_RESERVE_USDT=300
RISK_MAX_CONSECUTIVE_LOSSES=4
RISK_COOLDOWN_SEC=900
RISK_API_FAILURE_THRESHOLD=3
RISK_SHOCK_PCT=0.05
RISK_RECONCILE_STRICT=1
RISK_RECONCILE_TOLERANCE_PCT=0.02
RISK_MAX_TIME_OFFSET_MS=1000
RISK_MAX_TIME_RTT_MS=5000

# Optional notification webhook. Never include API secrets in the URL.
BOT_ALERT_WEBHOOK_URL=

# Dashboard: use a dedicated Binance key with read-only permission.
DASHBOARD_BINANCE_API_KEY=replace_with_read_only_key
DASHBOARD_BINANCE_API_SECRET=replace_with_read_only_secret
DASHBOARD_AUTH_TOKEN=replace_with_a_long_random_token
DASHBOARD_TRUST_PROXY_AUTH=0
DASHBOARD_ENABLE_LOGS=0
DASHBOARD_RATE_LIMIT_PER_MIN=120
DASHBOARD_SSE_MAX_CONNECTIONS=2
DASHBOARD_METRICS_MAX_BYTES=5242880
DASHBOARD_METRICS_ROTATIONS=3
