# Venue credentials. Testnet is the default.
BINANCE_TESTNET_API_KEY=replace_me
BINANCE_TESTNET_API_SECRET=replace_me
BINANCE_TESTNET_API_BASE=https://testnet.binance.vision

# Mainnet credentials are only read with --mainnet.
BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
BINANCE_API_BASE=https://api.binance.com

# LIVE requires the exact value YES. Keep unset for DRY mode.
BOT_LIVE_CONFIRMED=NO
# Separate confirmation used only by binance_testnet_smoke.py --mode limit-cancel.
BOT_TESTNET_ORDER_CONFIRMED=NO
# Allows a real Testnet MARKET BUY, verified OCO, cancellation and cleanup SELL.
BOT_TESTNET_BUY_OCO_CONFIRMED=NO
BOT_TESTNET_ORDER_JOURNAL=/home/bot/apps/binance_bot/db/testnet_order_intents.sqlite3
BOT_TESTNET_STATS_DB=/home/bot/apps/binance_bot/db/testnet_bot_stats.db
BOT_STATS_DB=/home/bot/apps/binance_bot/db/bot_stats.db
# Durable order intents; must survive process and host restarts.
BOT_ORDER_JOURNAL=/home/bot/apps/binance_bot/db/order_intents.sqlite3
BOT_RUN_DIR=/run/mybot
BOT_TESTNET_RUN_DIR=/run/mybot/testnet
# Exponential restart backoff for workers that exit quickly with an error.
BOT_CHILD_RESTART_BASE_SEC=2
BOT_CHILD_RESTART_MAX_SEC=60
BOT_CHILD_STABLE_SEC=30
CLEANUP_WARMUP_SEC=900
START_CLEANUP_OFFLADDER_GRACE_SEC=900
CLEANUP_OFFLADDER_GRACE_SEC=900
BOT_CAP_PER_ORDER=50

# Optional AI advisory layer. Disabled by default and has no order tools.
AI_ADVISOR_ENABLE=0
# DISABLED=no requests, SHADOW=measure only, APPLY=allow safe policy changes.
AI_MODE=SHADOW
AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
AI_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace_me
# Use OPENAI_API_KEY with AI_PROVIDER=openai. AI_API_KEY is only for a custom
# OpenAI-compatible endpoint selected with AI_PROVIDER=compatible.
OPENAI_API_KEY=replace_me
AI_API_KEY=replace_me
AI_TIMEOUT_SEC=10
# Не чаще одного нового запроса на символ за 15 минут: SHADOW успевает
# накопить статистику, но не расходует бюджет на повторяющиеся снимки.
AI_CACHE_SEC=900
AI_MIN_CONFIDENCE=0.65
AI_RAG_TOP_K=3
AI_WIDTH_SCALE_MIN=0.75
AI_WIDTH_SCALE_MAX=1.50
AI_CAP_SCALE_MIN=0.25
AI_CAP_SCALE_MAX=1.25
AI_USAGE_LOG=/home/bot/apps/binance_bot/logs/ai_usage.ndjson
AI_USAGE_LOG_MAX_BYTES=5242880
AI_DECISIONS_DB=/home/bot/apps/binance_bot/db/ai_decisions.sqlite3
AI_TESTNET_DECISIONS_DB=/home/bot/apps/binance_bot/db/testnet_ai_decisions.sqlite3
AI_RUNTIME_STATUS_FILE=/run/mybot/ai_status.json
# Runtime-переключатель из дашборда; не даёт AI доступ к ордерам.
AI_CONTROL_FILE=FastAPI/pi-dashboard/data/ai_control.json
# Консервативный дневной бюджет для DRY + SHADOW.
AI_DAILY_COST_LIMIT_USD=0.10
AI_DAILY_TOKEN_LIMIT=250000
AI_MAX_REQUESTS_PER_DAY=400
AI_MAX_MARKET_AGE_SEC=30
AI_MAX_PORTFOLIO_AGE_SEC=30
AI_MAX_SPREAD_BPS=25
AI_HIGH_VOLATILITY_PCT=0.04
AI_MIN_TRADE_SELLS=20
AI_MIN_ACCURACY_SAMPLES=30
AI_MIN_ACCURACY=0.50
# Optional price overrides in USD per 1M tokens. Leave unset to use built-in
# current DeepSeek V4 Flash/Pro prices; review them after provider price changes.
# AI_INPUT_CACHE_HIT_USD_PER_MTOK=
# AI_INPUT_CACHE_MISS_USD_PER_MTOK=
# AI_OUTPUT_USD_PER_MTOK=

# Circuit breaker (fractions: 0.03 = 3%).
CB_MAX_DAILY_LOSS_USDT=100
CB_MAX_START_DRAWDOWN_PCT=0.03
CB_MAX_PEAK_DRAWDOWN_PCT=0.02
CB_HALT_FILE=/run/mybot/circuit_halt.json
CB_STATE_FILE=/run/mybot/risk_state.json
CB_ALERTS_FILE=/run/mybot/risk_alerts.ndjson

# Portfolio risk limits.
RISK_PORTFOLIO_CAP_USDT=3000
RISK_DAILY_TURNOVER_CAP_USDT=5000
RISK_DAILY_TRADE_COUNT_CAP=120
RISK_DAILY_BUY_CAP_USDT=2500
RISK_OPEN_ORDER_COUNT_CAP=30
RISK_CORRELATED_SYMBOLS=SOLUSDT,ETHUSDT,TONUSDT
RISK_CORRELATED_CAP_USDT=2500
RISK_RESERVE_USDT=300
RISK_MAX_CONSECUTIVE_LOSSES=4
RISK_COOLDOWN_SEC=900
RISK_API_FAILURE_THRESHOLD=3
RISK_SHOCK_PCT=0.05
RISK_RECONCILE_STRICT=1
RISK_RECONCILE_TOLERANCE_PCT=0.02
# A recent fill may reach the account endpoint just before the worker commits it
# to SQLite. Strict reconciliation retries only for this bounded interval.
RISK_RECONCILE_GRACE_SEC=5
RISK_RECONCILE_RETRY_SEC=0.25
# Ignore only non-tradable base-asset dust/commission below this many LOT_SIZE steps.
RISK_RECONCILE_DUST_STEPS=1
RISK_MAX_TIME_OFFSET_MS=1000
RISK_MAX_TIME_RTT_MS=5000

# Optional notification webhook. Never include API secrets in the URL.
BOT_ALERT_WEBHOOK_URL=

# Telegram аварийные уведомления. Секреты на Raspberry хранятся отдельно в
# /etc/ladder-dragon/telegram.env (legacy /etc/bot-alerts.env поддерживается).
TELEGRAM_ALERTS_CONFIG=/etc/ladder-dragon/telegram.env
TELEGRAM_ALERTS_ENABLED=0

# Dashboard: use a dedicated Binance key with read-only permission.
DASHBOARD_BINANCE_API_KEY=replace_with_read_only_key
DASHBOARD_BINANCE_API_SECRET=replace_with_read_only_secret
DASHBOARD_AUTH_TOKEN=replace_with_a_long_random_token
DASHBOARD_TRUST_PROXY_AUTH=0
DASHBOARD_ENABLE_LOGS=0
DASHBOARD_RATE_LIMIT_PER_MIN=120
DASHBOARD_SSE_MAX_CONNECTIONS=2
DASHBOARD_METRICS_MAX_BYTES=5242880
DASHBOARD_METRICS_ROTATIONS=3
